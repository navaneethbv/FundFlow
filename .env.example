# ------------------------------------------------------------------
# FundFlow environment variables (copy to .env.local and fill in)
# .env.local is gitignored. NEVER commit real secrets.
# ------------------------------------------------------------------

# --- Supabase ---
# Project URL, e.g. https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Publishable key (safe in the browser; RLS enforces access). Format: sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key (server-only, privileged; bypasses RLS). Format: sb_secret_...
# NEVER expose this to the browser or commit it.
SUPABASE_SECRET_KEY=

# --- Plaid ---
# From https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | development | production  (build/test in sandbox first)
PLAID_ENV=sandbox
# Comma-separated Plaid products, e.g. transactions
PLAID_PRODUCTS=transactions
# Comma-separated country codes, e.g. US
PLAID_COUNTRY_CODES=US
# Optional. Plaid Link redirect_uri for OAuth institutions (most large US banks
# in production). Must EXACTLY match a redirect URI registered in the Plaid
# dashboard. Leave unset for sandbox / non-OAuth banks. Requires https.
#   PLAID_REDIRECT_URI=https://your-domain.com/dashboard
PLAID_REDIRECT_URI=

# --- App crypto ---
# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Used to AES-256-GCM encrypt Plaid access tokens at rest.
PLAID_TOKEN_ENC_KEY=
# Key rotation (optional): move the old key here, put a fresh key above, and
# redeploy. Decryption falls back to this key, and the daily sync re-encrypts
# every token with the new key — after one clean sync you can remove this.
PLAID_TOKEN_ENC_KEY_PREVIOUS=

# --- Cron ---
# Shared secret guarding the scheduled sync route. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# --- Email (weekly report and daily digest) ---
# SMTP credentials for financial email (e.g. Resend, Postmark, SES).
# Required in production: without them delivery fails safely and is recorded.
# In dev, leaving them empty falls back to Ethereal + a preview URL.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# From address, e.g. "FundFlow <reports@yourdomain.com>"
SMTP_FROM=

# --- App ---
# Public base URL of the app (used for Plaid redirect/OAuth if enabled)
NEXT_PUBLIC_APP_URL=http://localhost:3000
